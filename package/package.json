{
  "name": "@overextended/ox_lib",
  "author": "Overextended",
  "version": "3.33.1",
  "description": "JS/TS wrapper for ox_lib exports",
  "exports": {
    ".": {
      "import": "./dist/common/index.js",
      "types": "./dist/common/index.d.ts"
    },
    "./*": {
      "import": "./dist/common/*/index.js",
      "types": "./dist/common/*/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./client/*": {
      "import": "./dist/client/*/index.js",
      "types": "./dist/client/*/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./server/*": {
      "import": "./dist/server/*/index.js",
      "types": "./dist/server/*/index.d.ts"
    }
  },
  "sideEffects": [
    "./common/locale/index.js"
  ],
  "scripts": {
    "compile": "tsc",
    "format": "prettier . --write",
    "prepublishOnly": "bun run format & bun run compile"
  },
  "keywords": [
    "fivem",
    "ox_lib",
    "ox",
    "overextended",
    "overextended"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/overextended/ox_lib.git"
  },
  "bugs": {
    "url": "https://github.com/overextended/ox_lib/issues"
  },
  "license": "LGPL-3.0",
  "dependencies": {
    "@nativewrappers/fivem": "^0.0.103",
    "@overextended/core": "^0.2.5",
    "csstype": "^3.1.3",
    "fast-printf": "^1.6.9",
    "typescript": "^5.4.2"
  },
  "devDependencies": {
    "@citizenfx/client": "latest",
    "@citizenfx/server": "latest",
    "@fortawesome/fontawesome-common-types": "6.1.1",
    "@mantine/core": "^6.0.21",
    "@types/node": "16.9.1",
    "@types/react": "^18.2.66",
    "barrelize": "^1.8.0",
    "prettier": "^3.8.3"
  }
}
